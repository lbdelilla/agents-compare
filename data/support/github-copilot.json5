// Support matrix for GitHub Copilot AI coding agent
// This file defines how well GitHub Copilot supports various features
{
  agent_id: "github-copilot",
  feature_support: [
    {
      feature_id: "mcp-support",
      support_level: "yes",
      notes: "GitHub Copilot supports MCP (Model Context Protocol) servers in VS Code, JetBrains, and Xcode, available in Agent Mode. Users can connect MCP tools directly from the Copilot panel.",
      examples: ["Connecting to a database via MCP in Agent Mode", "Using custom MCP tools for repository analysis"],
      last_verified: "2026-03-16",
      sources: ["https://github.blog/changelog/2025/04/04/github-copilot-now-supports-mcp-servers-in-public-preview-in-vs-code/"]
    },
    {
      feature_id: "context-window",
      support_level: "partial",
      notes: "Limited context window focused on current file and immediate surrounding files. Doesn't maintain conversation history like chat-based agents.",
      examples: ["Analyzes current file and imports for suggestions"],
      last_verified: "2024-01-15",
      sources: ["https://docs.github.com/en/copilot/using-github-copilot/getting-started-with-github-copilot"]
    },
    {
      feature_id: "claude3-support",
      support_level: "yes",
      notes: "GitHub Copilot now supports multiple models including Claude Sonnet 4.5/4.6, Claude Haiku 4.5, and Claude Opus 4.6, alongside GPT-4o, GPT-4.1, and Gemini 2.0. Users can switch models from the Copilot model picker.",
      examples: ["Using Claude Sonnet 4.6 for complex refactoring in Agent Mode", "Switching to Claude Haiku 4.5 for faster completions"],
      last_verified: "2026-03-16",
      sources: ["https://docs.github.com/en/copilot/about-github-copilot/plans-for-github-copilot", "https://github.blog/changelog/2026/02/github-copilot-claude-model-support/"]
    },
    {
      feature_id: "filesystem-access",
      support_level: "yes",
      notes: "In Agent Mode (GA in VS Code since February 2025), GitHub Copilot can autonomously create, modify, and delete files across the workspace without manual intervention.",
      examples: ["Agent Mode creating new component files", "Autonomously refactoring multi-file codebases"],
      last_verified: "2026-03-16",
      sources: ["https://github.blog/news-insights/product-news/github-copilot-coding-agent-is-now-generally-available/"]
    },
    {
      feature_id: "planner-strategy",
      support_level: "yes",
      notes: "Agent Mode (GA in VS Code since February 2025) and Copilot Workspace (GA for all Pro/Business/Enterprise subscribers) provide full multi-step planning: generating a plan, writing code, running tests, and iterating autonomously.",
      examples: ["Using Copilot Workspace to plan and implement a new feature end-to-end", "Agent Mode breaking a task into steps and executing them autonomously"],
      last_verified: "2026-03-16",
      sources: ["https://github.blog/news-insights/product-news/github-copilot-coding-agent-is-now-generally-available/", "https://github.blog/news-insights/product-news/github-copilot-workspace-is-now-generally-available/"]
    },
    {
      feature_id: "automatic-context-awareness",
      support_level: "partial",
      notes: "GitHub Copilot automatically analyzes the current file, imports, and nearby files to provide context-aware suggestions. However, context is limited compared to full-codebase agents and doesn't include external resources or deep project understanding.",
      examples: [
        "Analyzes current file and imported modules automatically",
        "Suggests code based on function signatures in the file",
        "Uses comments and variable names for context"
      ],
      last_verified: "2025-11-12",
      sources: [
        "https://docs.github.com/en/copilot/using-github-copilot/getting-code-suggestions-in-your-ide-with-github-copilot"
      ]
    },
    {
      feature_id: "broad-ide-integration",
      support_level: "yes",
      notes: "GitHub Copilot has excellent IDE integration across multiple platforms including VS Code, Visual Studio, JetBrains IDEs (IntelliJ, PyCharm, etc.), Neovim, and Emacs, making it one of the most widely supported AI coding assistants.",
      examples: [
        "VS Code extension with inline suggestions",
        "JetBrains plugin for IntelliJ IDEA, PyCharm, WebStorm, etc.",
        "Neovim plugin via copilot.vim",
        "Emacs integration via copilot.el",
        "Visual Studio extension"
      ],
      last_verified: "2025-11-12",
      sources: [
        "https://docs.github.com/en/copilot/using-github-copilot/getting-started-with-github-copilot",
        "https://github.com/features/copilot"
      ]
    },
    {
      feature_id: "claude-4-support",
      support_level: "yes",
      notes: "GitHub Copilot supports Claude Opus 4.6 (generally available as of February 2026) and Claude Sonnet 4.6 via the model picker. Users can select Claude models for different tasks directly in the Copilot chat panel.",
      examples: ["Using Claude Opus 4.6 for complex architectural refactoring", "Selecting Claude Sonnet 4.6 for faster code generation tasks"],
      last_verified: "2026-03-16",
      sources: [
        "https://github.blog/changelog/2026/02/github-copilot-claude-model-support/"
      ]
    },
    {
      feature_id: "console-error-integration",
      support_level: "no",
      notes: "GitHub Copilot does not have integrated web preview functionality or console error capture. It works within the code editor context only and doesn't monitor runtime errors from running applications.",
      examples: [],
      last_verified: "2025-11-12",
      sources: [
        "https://docs.github.com/en/copilot/using-github-copilot"
      ]
    },
    {
      feature_id: "dedicated-instruction-file",
      support_level: "yes",
      notes: "GitHub Copilot supports .github/copilot-instructions.md for repository-wide instructions in natural language Markdown. Generally available since 2025, it lets teams define coding standards, preferred libraries, and response styles.",
      examples: ["Defining TypeScript naming conventions in copilot-instructions.md", "Setting project-specific architecture rules for all contributors"],
      last_verified: "2026-03-16",
      sources: [
        "https://docs.github.com/en/copilot/customizing-copilot/adding-custom-instructions-for-github-copilot"
      ]
    },
    {
      feature_id: "fine-grained-instruction-control",
      support_level: "partial",
      notes: "Since November 2025, Copilot supports multiple .instructions.md files with YAML frontmatter to target specific paths or agents (e.g., applyTo: '**/*.ts'). However, glob pattern support is less flexible than Cursor's .cursor/rules system.",
      examples: ["Applying strict null-check rules only to TypeScript files", "Setting different instructions for front-end vs back-end agents"],
      last_verified: "2026-03-16",
      sources: [
        "https://docs.github.com/en/copilot/customizing-copilot/adding-repository-custom-instructions-for-github-copilot"
      ]
    },
    {
      feature_id: "interactive-element-selection",
      support_level: "no",
      notes: "GitHub Copilot does not have UI preview or element selection capabilities. It operates purely within the code editor and doesn't interact with rendered applications or allow selecting UI elements to reference in prompts.",
      examples: [],
      last_verified: "2025-11-12",
      sources: [
        "https://docs.github.com/en/copilot"
      ]
    },
    {
      feature_id: "live-web-preview",
      support_level: "no",
      notes: "GitHub Copilot does not include an integrated web preview feature. It focuses on code suggestions within the IDE and doesn't render or preview web applications.",
      examples: [],
      last_verified: "2025-11-12",
      sources: [
        "https://docs.github.com/en/copilot/using-github-copilot"
      ]
    },
    {
      feature_id: "supports-scoped-instructions",
      support_level: "yes",
      notes: "Copilot supports scoped instructions at repository level (.github/copilot-instructions.md), agent-specific level, and path-specific level via multiple .instructions.md files with YAML frontmatter (generally available since November 2025).",
      examples: ["Repository-wide style guide in copilot-instructions.md", "Agent-specific instructions for the coding agent vs chat assistant"],
      last_verified: "2026-03-16",
      sources: [
        "https://docs.github.com/en/copilot/customizing-copilot/adding-repository-custom-instructions-for-github-copilot"
      ]
    }
  ]
} 