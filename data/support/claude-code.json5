      notes: "Claude Code has official plugins for VS Code and the full JetBrains family (IntelliJ IDEA, PyCharm, WebStorm, etc.), plus community Neovim integration via claude-code.nvim.",
      examples: ["Using Claude Code in VS Code for code generation", "Integrating with JetBrains for advanced refactoring", "Using claude-code.nvim for Neovim integration"],
      last_verified: "2026-03-16",
      sources: ["https://docs.anthropic.com/en/docs/claude-code/ide-integrations", "https://github.com/anthropics/claude-code.nvim"]
    },
    {
